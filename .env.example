# ===================
# Server Configuration
# ===================
PORT=3000
NODE_ENV=production

# ===================
# Database (PostgreSQL)
# ===================
# Use 'db' when running via docker-compose, 'localhost' for local dev
DB_HOST=db
DB_PORT=5432
DB_NAME=mediaunboxed
DB_USER=postgres
DB_PASSWORD=

# ===================
# License Encryption
# ===================
# Comma-separated keys (first = primary for new licenses)
# Keys must be exactly 32 characters for AES-256
LICENSE_ENCRYPTION_KEYS=PrimaryKey32BytesLongSecretHere!,OldKeyForBackwardCompatibility!

# ===================
# API Security
# ===================
API_KEY=your-admin-api-key-here

# ===================
# Email (Future)
# ===================
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=

# ===================
# Payment (Future)
# ===================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
